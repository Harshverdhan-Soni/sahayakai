# ─────────────────────────────────────────────────────────────────
# SAHAYAK-AI Backend — Environment Configuration
# ⚠ NEVER commit this file to Git — add .env to .gitignore
# ─────────────────────────────────────────────────────────────────

# ── iHRMS PostgreSQL (Docker) ─────────────────────────────────────
# Container: postgres_16
# Host port: 5434 (mapped from container's 5432)
# Database:  hrmis (as seen in pgAdmin)
# Schema:    hrms  (the schema with 78 tables)





# New Credentials: postgres / cdacsil (as set in Dockerfile)
IHRMS_HOST=localhost
IHRMS_PORT=5434
IHRMS_DB=hrmis
IHRMS_SCHEMA=hrms
IHRMS_USER=postgres
IHRMS_PASSWORD=cdacsil

# SQLAlchemy async URL — used by ihrms_db.py
# asyncpg driver required: pip install asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:cdacsil@localhost:5434/hrmis

# ── Ollama (Local LLM) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── FastAPI Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=sahayak-dev-secret-change-in-production

# ── Audit Log (SQLite) ────────────────────────────────────────────
AUDIT_DB_PATH=./audit.db

# ── pgAdmin (for reference only — not used by backend) ───────────
# URL:      http://localhost:5051
# Email:    user@domain.com
# Password: SuperSecret
